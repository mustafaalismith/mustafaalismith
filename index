<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Name</title>
    <meta name="description" content="Your description here.">
    <meta name="author" content="Your Name">
    <meta name="keywords" content="research, portfolio, data">

    <meta property="og:url" content="www.yoursite.com">
    <meta property="og:type" content="website">
    <meta property="og:title" content="Your Name">
    <meta property="og:description" content="Your description here.">
    <meta property="og:image" content="">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
      body { padding: 0; margin: 0; background: #F4F0EC; }

      main {
        height: 95%;
        font-family: 'Libre Franklin', sans-serif;
      }

      main p, .navButton, .fa-brands { color: #111111; }

      main h1 { font-weight: 500; font-size: inherit; }

      section .subContent, .navButton, .selectedWorkEntry {
        font-family: 'Libre Franklin', sans-serif;
        font-weight: 300;
      }

      button {
        border: none;
        font-size: 1em;
        display: block;
        background: #F4F0EC;
        cursor: pointer;
      }

      .navButton {
        text-decoration: none;
        transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out;
      }

      .resumeDownloadContainer { display: flex; flex-wrap: wrap; justify-content: space-around; }

      .resumeButton {
        flex: 0 1 auto;
        border: 1px solid #111111;
        padding: 0.4em;
        border-radius: 3px;
        transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out;
      }

      .resumeButton:hover {
        border: 1px solid #111111;
        border-radius: 3px;
        background-color: #9EBDAE;
        color: #111111;
      }

      button:hover { transition: color 0.25s linear; color: #9EBDAE; }
      button:active { color: #9EBDAE; }

      .closed { display: none; }
      .open { display: block; }

      .subContent > p { margin-bottom: 1em; margin-left: auto; margin-right: auto; }

      #aboutContent a { color: #111111; transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out; }
      #aboutContent a:hover { color: #9EBDAE; }

      #resumeContent a { color: #111111; }
      #resumeContent a:visited { color: #111111; }
      #resumeContent a:hover { color: #9EBDAE; transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out; }

      #contactContent a { display: inline-block; width: auto; color: #111111; }
      #contactContent a:visited { color: #111111; }
      #contactContent a:hover { color: #9EBDAE; transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out; }

      .filterContainer { display: flex; margin-top: 0.5em; flex-wrap: wrap; }

      .workFilter {
        border: 1px solid #111111;
        padding: 0.5em 2em;
        margin: 0;
        flex: 1 1 auto;
        font-size: 0.75em;
        transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out;
      }

      .workFilter:hover { border: 1px solid #111111; background: #9EBDAE; color: #111111; }

      .activeButton { background: #9EBDAE; }
      .inactiveButton { background: #F4F0EC; }

      .selectedWorkEntry {
        background-color: #F4F0EC;
        color: #111111;
        text-align: left;
        text-decoration: none;
        display: inline-block;
        font-size: 1em;
        border-bottom: 1px solid #111111;
      }

      .selectedWorkEntry:last-child { border-bottom: none; }

      .selectedWorkEntry:hover {
        background-color: #9EBDAE;
        color: #111111;
        transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out;
        cursor: pointer;
      }

      .selectedWorkPhoto { margin: 0; padding: 15px 15px 15px 0; width: 25%; float: left; }
      .selectedWorkEntryTitle { font-size: 1.25em; margin: 0; padding: 0; display: block; }
      .selectedWorkEntryJob { padding-top: 0.25em; font-size: 1em; display: block; }
      .selectedWorkEntryCoAuthor { padding-top: 0.25em; font-size: 1em; font-style: italic; display: block; }
      .selectedWorkEntryAdditionalInfo { padding-top: 0.25em; font-size: 1em; display: block; }

      .resumeTable { display: block; }

      table { display: block; box-sizing: border-box; margin: 0 7.5% 2% 0; }
      table:first-child { margin-top: 1%; }

      td { padding: 5px 20px 5px 0; vertical-align: text-top; text-align: left; width: auto; }
      .tableTitle { font-weight: 600; }
      .date { font-weight: 600; }

      footer { position: fixed; right: 0; bottom: 0; margin: 0 1% 2% 0; text-align: center; }
      footer a { display: inline-block; width: auto; margin: 10px 10px; color: #111111; }
      footer a:visited { color: #111111; }
      footer a:hover { transition: color .15s ease-in-out; color: #9EBDAE; }

      .sr-only { position: absolute; left: -10000px; top: auto; width: 1px; height: 1px; overflow: hidden; }

      /* Desktop */
      @media screen and (min-width: 800px) {
        main { font-size: 4.8vw; display: block; margin: 2% 1%; }
        main h1 { margin: 0 0 0 2%; padding: 0; }
        div { display: block; }
        #headshot { width: 30%; padding: 0 2% 2% 0; float: left; }
        .fa-plus { font-size: 0.5em; padding: 0.25em; }
        .fa-brands { font-size: 0.5em; }
        .navButton { display: block; margin: 0 2% 0 2%; }
        .subContent { padding: 0 5% 0 3%; font-size: 0.35em; line-height: 130%; text-align: justify; }
        #aboutContent { width: 92.5%; }
        .selectedWorkEntry { padding: 15px 2%; width: 100%; margin: 0 auto; font-size: 0.8em; }
        td { font-size: 0.8em; min-width: 125px; }
        .resumeDownloadContainer { display: block; }
        .resumeButton { display: inline-block; margin: 10px 10px 10px 0; }
        #contactContent > a { font-size: 0.8em; }
      }

      /* Tablet */
      @media screen and (min-width: 481px) and (max-width: 799px) {
        main { font-size: 6vw; display: block; margin: 4% 2%; }
        main h1 { margin-right: 2%; margin-bottom: 0; padding: 0; font-size: 10vw; }
        div { display: block; }
        #headshot { width: 95%; padding: 0 0 2% 2%; }
        .fa-plus { font-size: 0.75em; padding-right: 0.25em; margin: 0; }
        .fa-brands { font-size: 0.5em; }
        .navButton { font-size: 1.75em; display: block; margin: 0 0 0 2%; }
        .subContent { padding: 0 5% 0 3%; font-size: 0.7em; line-height: 130%; text-align: justify; }
        #aboutContent { width: 85%; }
        .selectedWorkEntry { padding: 15px 2%; width: 95%; margin: 0 auto; font-size: 0.8em; }
        .filterContainer { width: 95%; }
        .resumeDownloadContainer { width: 100%; }
        .resumeButton { margin: 10px 10px 10px 0; }
        table { width: 100%; }
        td { font-size: 0.8em; min-width: 125px; }
        .date { font-weight: 600; }
        #contactContent > a { font-size: 0.8em; }
      }

      /* Mobile */
      @media screen and (min-width: 320px) and (max-width: 480px) {
        main { font-size: 10vw; display: block; margin: 1%; }
        main h1 { margin-left: 2%; margin-bottom: 0; padding: 0; font-size: 11vw; }
        div { display: block; }
        .fa-plus { font-size: 0.5em; padding: 0.25em; }
        .navButton { display: block; margin-left: 2%; }
        .subContent { padding: 0 5% 0 3%; font-size: 0.45em; line-height: 130%; text-align: justify; }
        #aboutContent { width: 90%; margin: 0 auto; }
        #headshot { width: 100%; }
        #workContent { width: 90%; margin: 0 auto; }
        .selectedWorkPhoto { display: none; }
        .selectedWorkEntry { padding: 15px; width: 100%; margin: 0 auto; }
        .filterContainer { padding: 0; width: 100%; margin: 0 auto; }
        #resumeContent { width: 90%; margin: 0 auto; }
        table { width: 100%; }
        tr { width: 100%; }
        td { min-width: 50px; }
        .date { font-weight: 600; }
        footer { display: none; }
      }
    </style>
  </head>

  <body>

    <header></header>

    <main>

      <!-- PAGE HEADER — update with your name, title, and city -->
      <h1>
        Your Name,
        <br>Your title or role,
        <br>Your City, State
      </h1>

      <!-- ABOUT -->
      <button type="button" class="navButton" onclick="menuOpenClose('aboutContent')"><i class="fa-solid fa-plus"></i> About</button>

      <section class="subContent closed" id="aboutContent">

        <!-- Replace src with your photo: e.g. src="images/headshot.jpg" -->
        <img id="headshot" src="images/headshot.jpg" alt="Your Name headshot">

        <p><b>Write your opening sentence here — something that captures who you are and what you do.</b> Describe your current role and where you work, linking to <a href="https://yourorg.com" target="_blank">relevant organizations</a>.</p>

        <p>Add more about your current work — projects, teaching, research, or other responsibilities.</p>

        <p>Describe a previous role and what you accomplished there. Use <a href="#" target="_blank">links</a> to point to relevant work or organizations.</p>

        <p>Add another prior role or area of focus if relevant.</p>

        <p>Write a sentence about your broader interests or what ties your work together.</p>

        <p>Close with your educational background — degrees, institutions, and years.</p>

      </section>

      <!-- SELECTED WORK -->
      <button type="button" class="navButton" onclick="menuOpenClose('workContent')"><i class="fa-solid fa-plus"></i> Selected Work</button>

      <section class="subContent closed" id="workContent">

        <!-- Update filter button labels and IDs to match your categories -->
        <div class="filterContainer">
          <button type="button" class="workFilter activeButton"   id="allFilterButton"       onclick="menuFilter('allFilter');       menuActive('allFilterButton')">All</button>
          <button type="button" class="workFilter inactiveButton" id="category1FilterButton" onclick="menuFilter('category1Filter'); menuActive('category1FilterButton')">Category 1</button>
          <button type="button" class="workFilter inactiveButton" id="category2FilterButton" onclick="menuFilter('category2Filter'); menuActive('category2FilterButton')">Category 2</button>
          <button type="button" class="workFilter inactiveButton" id="category3FilterButton" onclick="menuFilter('category3Filter'); menuActive('category3FilterButton')">Category 3</button>
          <button type="button" class="workFilter inactiveButton" id="category4FilterButton" onclick="menuFilter('category4Filter'); menuActive('category4FilterButton')">Category 4</button>
        </div>

        <!-- WORK ITEM — duplicate this block for each project.
             Add category classes to match your filters above.
             e.g. class="selectedWorkEntry allFilter category1Filter category2Filter" -->

        <button type="button" class="selectedWorkEntry allFilter category1Filter" onclick="window.open('https://your-link-here.com','_blank')">
          <img class="selectedWorkPhoto" src="images/work1.jpg" alt="Project 1 thumbnail">
          <span class="selectedWorkEntryTitle">"Title of Your First Work or Project"</span>
          <span class="selectedWorkEntryJob">Type of work authored for Organization or Publication</span>
          <span class="selectedWorkEntryCoAuthor">Co-authored with Collaborator Name and Another Name</span>
          <span class="selectedWorkEntryAdditionalInfo">Month Year</span>
        </button>

        <button type="button" class="selectedWorkEntry allFilter category2Filter" onclick="window.open('https://your-link-here.com','_blank')">
          <img class="selectedWorkPhoto" src="images/work2.jpg" alt="Project 2 thumbnail">
          <span class="selectedWorkEntryTitle">"Title of Your Second Work"</span>
          <span class="selectedWorkEntryJob">Op-ed / Blog post / Report authored for <i>Publication Name</i></span>
          <span class="selectedWorkEntryAdditionalInfo">Month Year</span>
        </button>

        <button type="button" class="selectedWorkEntry allFilter category1Filter category3Filter" onclick="window.open('https://your-link-here.com','_blank')">
          <img class="selectedWorkPhoto" src="images/work3.jpg" alt="Project 3 thumbnail">
          <span class="selectedWorkEntryTitle">Title of Third Work (No Quotes if Not a Publication Title)</span>
          <span class="selectedWorkEntryJob">Research project for Organization</span>
          <span class="selectedWorkEntryCoAuthor">Co-authored with Collaborator Name</span>
          <span class="selectedWorkEntryAdditionalInfo">Month Year</span>
        </button>

        <button type="button" class="selectedWorkEntry allFilter category4Filter" onclick="window.open('https://your-link-here.com','_blank')">
          <img class="selectedWorkPhoto" src="images/work4.jpg" alt="Project 4 thumbnail">
          <span class="selectedWorkEntryTitle">Title of Fourth Work</span>
          <span class="selectedWorkEntryJob">Conference paper authored for Conference Name</span>
          <span class="selectedWorkEntryCoAuthor">Co-authored with Collaborator Name</span>
          <span class="selectedWorkEntryAdditionalInfo">Month Year</span>
        </button>

      </section>

      <!-- RESUME -->
      <button type="button" class="navButton" onclick="menuOpenClose('resumeContent')"><i class="fa-solid fa-plus"></i> Resume</button>

      <section class="subContent closed" id="resumeContent">

        <div class="resumeDownloadContainer">
          <!-- Point these to your actual PDF files in an /assets folder -->
          <button type="button" class="resumeButton" onclick="window.open('assets/Your Name Resume.pdf','_blank')">VIEW RESUME</button>
          <button type="button" class="resumeButton" onclick="window.open('assets/Your Name CV.pdf','_blank')">VIEW FULL C/V</button>
        </div>

        <div class="resumeTable">

          <table>
            <tr><th class="tableTitle" colspan="2">EDUCATION</th></tr>
            <tr>
              <td class="date">2020 – 2022</td>
              <td>
                University Name, School Name
                <br>Degree, Field
                <br><i>Certificate in Something</i>
              </td>
            </tr>
            <tr>
              <td class="date">2016 – 2020</td>
              <td>
                University Name, School Name
                <br>Degree, Field
                <br><i>Certificate in Something</i>
              </td>
            </tr>
            <tr>
              <td class="date">2012 – 2016</td>
              <td>
                University Name
                <br>Degree, Field
              </td>
            </tr>
          </table>

          <table>
            <tr><th class="tableTitle" colspan="2">PROFESSIONAL EXPERIENCE</th></tr>
            <tr>
              <td class="date">2022 – Pres.</td>
              <td>Job Title, Organization, City, State</td>
            </tr>
            <tr>
              <td class="date">2022 – Pres.</td>
              <td>
                Second Current Role, Organization
                <br>Course: <a href="#" target="_blank"><i>Course Name</i></a>
              </td>
            </tr>
            <tr>
              <td class="date">2020 – 2022</td>
              <td>
                Senior Role Title (Jan – Oct 2022), Organization, City, State
                <br>Junior Role Title (May 2020 – Dec 2021), Organization, City, State
              </td>
            </tr>
            <tr>
              <td class="date">2018 – 2020</td>
              <td>Role Title, Organization, City, State</td>
            </tr>
            <tr>
              <td class="date">2017 – 2018</td>
              <td>Role Title, Organization, City, State</td>
            </tr>
            <tr>
              <td class="date">2013 – 2015</td>
              <td>Role Title, Organization, City, State</td>
            </tr>
          </table>

          <table>
            <tr><th class="tableTitle" colspan="2">ACADEMIC EXPERIENCE</th></tr>
            <tr>
              <td class="date">2016 – 2020</td>
              <td>
                Predoctoral Fellow / Research Fellow, Institution
                <br><a href="#" target="_blank"><i>Dissertation: "Your Dissertation Title Here"</i></a>
                <br>Thesis advisor: <a href="#" target="_blank">Advisor Name, PhD</a>
              </td>
            </tr>
            <tr>
              <td class="date">2014 – 2016</td>
              <td>
                Research Assistant, Institution
                <br>Department Name
                <br>Principal Investigator: <a href="#" target="_blank">PI Name, PhD</a>
              </td>
            </tr>
            <tr>
              <td class="date">2013</td>
              <td>
                <a href="#" target="_blank">Fellowship / Program Name, Institution</a>
                <br>Principal Investigator: <a href="#" target="_blank">PI Name, MD, PhD</a>
              </td>
            </tr>
          </table>

          <table>
            <tr><th class="tableTitle" colspan="2">LEADERSHIP</th></tr>
            <tr>
              <td class="date">2021</td>
              <td>Role, Organization</td>
            </tr>
            <tr>
              <td class="date">2019 – 2020</td>
              <td>Role, Organization</td>
            </tr>
            <tr>
              <td class="date">2017 – 2018</td>
              <td>Co-Chair, <a href="#" target="_blank">Group Name</a>,
                <br>Institution Name</td>
            </tr>
            <tr>
              <td class="date">2017</td>
              <td>Student Representative, Field Name,
                <br>Institution Name</td>
            </tr>
          </table>

          <table>
            <tr><th class="tableTitle" colspan="2">SKILLS</th></tr>
            <tr>
              <td><b>Programming:</b></td>
              <td>Python, R, JavaScript, SQL, git</td>
            </tr>
            <tr>
              <td><b>Statistics and Data Analysis:</b></td>
              <td>Regression, clustering, classification, data modeling, descriptive analyses</td>
            </tr>
            <tr>
              <td><b>Data Visualization:</b></td>
              <td>Tableau, R (ggplot2), Excel, Google Sheets</td>
            </tr>
            <tr>
              <td><b>Geospatial Analysis:</b></td>
              <td>ArcGIS, QGIS, R (sf, leaflet)</td>
            </tr>
            <tr>
              <td><b>Project Management:</b></td>
              <td>Project scoping, research design and evaluation</td>
            </tr>
          </table>

        </div>
      </section>

      <!-- CONTACT -->
      <button type="button" class="navButton" onclick="menuOpenClose('contactContent')"><i class="fa-solid fa-plus"></i> Contact</button>

      <section class="subContent closed" id="contactContent">
        <a href="mailto:you@email.com" target="_blank">Email</a>
        <br>
        <a href="https://www.linkedin.com/in/yourhandle/" target="_blank">LinkedIn</a>
        <br>
        <a href="https://github.com/yourhandle" target="_blank">GitHub</a>
      </section>

    </main>

    <footer>
      <a href="mailto:you@email.com" target="_blank">
        <i class="fa-solid fa-envelope fa-2xl" aria-hidden="true"></i>
        <span class="sr-only">Email</span>
      </a>
      <br>
      <a href="https://www.linkedin.com/in/yourhandle/" target="_blank">
        <i class="fa-brands fa-linkedin fa-2xl" aria-hidden="true"></i>
        <span class="sr-only">LinkedIn</span>
      </a>
      <br>
      <a href="https://github.com/yourhandle" target="_blank">
        <i class="fa-brands fa-github fa-2xl" aria-hidden="true"></i>
        <span class="sr-only">GitHub</span>
      </a>
    </footer>

    <script>
      function menuOpenClose(par) {
        var clickedSection = par;
        const sections = ["aboutContent", "workContent", "resumeContent", "contactContent"];
        var otherSections = sections.filter(function(value) {
          return value != clickedSection;
        });
        var x = document.getElementById(par);
        var y = document.querySelectorAll(otherSections.map(id => '#' + id).join(', '));

        if (x.className == "subContent closed") {
          x.className = "subContent open";
          y[0].className = "subContent closed";
          y[1].className = "subContent closed";
          y[2].className = "subContent closed";
        } else {
          x.className = "subContent closed";
          y[0].className = "subContent closed";
          y[1].className = "subContent closed";
          y[2].className = "subContent closed";
        }
      }

      function menuFilter(par) {
        var x = document.getElementsByClassName('selectedWorkEntry');
        for (var i = 0; i < x.length; i++) {
          if (!x[i].classList.contains(par)) {
            x[i].style.display = "none";
          } else {
            x[i].style.display = "block";
          }
        }
      }

      function menuActive(par) {
        var clickedFilterButton = par;
        const filterButtons = ["allFilterButton", "category1FilterButton", "category2FilterButton", "category3FilterButton", "category4FilterButton"];
        var otherFilterButtons = filterButtons.filter(function(value) {
          return value != clickedFilterButton;
        });
        var x = document.getElementById(par);
        var y = document.querySelectorAll(otherFilterButtons.map(id => '#' + id).join(', '));

        x.className = "workFilter activeButton";
        y[0].className = "workFilter inactiveButton";
        y[1].className = "workFilter inactiveButton";
        y[2].className = "workFilter inactiveButton";
        y[3].className = "workFilter inactiveButton";
      }
    </script>

  </body>
</html>
